# === LLM Configuration ===
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1
LLM_API_KEY=

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./fitness_coach.db

# === Scheduler ===
MORNING_HOUR=7
MORNING_MINUTE=30
EVENING_HOUR=21
EVENING_MINUTE=0
TIMEZONE=Europe/Paris

# === Vision (Scan repas par photo — Google Gemini) ===
VISION_PROVIDER=gemini
VISION_API_KEY=your-gemini-api-key-here
VISION_MODEL=gemini-2.5-flash

# === MCP Integrations ===
MCP_ENABLED=false
MCP_INTERNAL_STDIO_ENABLED=false
MCP_INTERNAL_SERVER_COMMAND=python
MCP_INTERNAL_SERVER_ARGS=-m agents.mcp.internal_server
# Example JSON:
# MCP_SERVERS_JSON={"nutrition":{"transport":"http","url":"https://example.com/mcp"}}
MCP_SERVERS_JSON=

# === App ===
LOG_LEVEL=INFO
DEBUG=false

# === API / Apple Health companion sync ===
API_HOST=0.0.0.0
PORT=8000
API_PUBLIC_URL=https://your-railway-domain.up.railway.app
HEALTHKIT_LINK_TTL_MINUTES=30
